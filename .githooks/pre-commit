#!/bin/sh
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/check-diff-coverage.ps1"
else
  powershell -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/check-diff-coverage.ps1"
fi
